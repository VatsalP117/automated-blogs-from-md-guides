---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CollectionCard from "@/components/CollectionCard.astro";
import { loadSiteContent } from "@/lib/content/load-site";
import { withBase } from "@/lib/paths";
import Layout from "@/layouts/Layout.astro";
import type { ContentCollection } from "@/lib/content/types";

export async function getStaticPaths() {
	const site = await loadSiteContent();

	return site.collections.map((collection) => ({
		params: {
			collection: collection.route,
		},
		props: {
			collection,
		},
	}));
}

const { collection } = Astro.props as { collection: ContentCollection };
---

<Layout title={collection.title} description={collection.description}>
	<Breadcrumbs items={[{ label: "Home", href: withBase() }, { label: collection.title }]} />

	<div class="page-header">
		<h1>{collection.title}</h1>
		<p>{collection.description}</p>
		<div class="page-meta">
			<span>{collection.itemCount} item{collection.itemCount === 1 ? "" : "s"}</span>
			<span>{collection.entryCount} source file{collection.entryCount === 1 ? "" : "s"}</span>
		</div>
	</div>

	<div class="item-list">
		{collection.items.map((item) => (
			<CollectionCard
				href={withBase(`${collection.route}/${item.slug}/`)}
				title={item.title}
				description={item.description}
				badges={[
					`${item.entries.length} part${item.entries.length === 1 ? "" : "s"}`,
					`${item.readingMinutes} min read`,
				]}
			/>
		))}
	</div>
</Layout>
