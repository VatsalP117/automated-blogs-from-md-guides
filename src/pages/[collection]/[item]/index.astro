---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import EntryList from "@/components/EntryList.astro";
import SectionNotes from "@/components/SectionNotes.astro";
import { loadSiteContent } from "@/lib/content/load-site";
import { withBase } from "@/lib/paths";
import Layout from "@/layouts/Layout.astro";
import type { ContentCollection, ContentItem } from "@/lib/content/types";

export async function getStaticPaths() {
	const site = await loadSiteContent();

	return site.collections.flatMap((collection) =>
		collection.items.map((item) => ({
			params: {
				collection: collection.route,
				item: item.slug,
			},
			props: {
				collection,
				item,
			},
		})),
	);
}

const { collection, item } = Astro.props as {
	collection: ContentCollection;
	item: ContentItem;
};
---

<Layout title={item.title} description={item.description}>
	<div class="route-shell">
		<Breadcrumbs
			items={[
				{ label: "Home", href: withBase() },
				{ label: collection.title, href: withBase(`${collection.route}/`) },
				{ label: item.title },
			]}
		/>

		<section class="panel hero-panel">
			<span class="eyebrow">{item.typeLabel}</span>
			<h1>{item.title}</h1>
			<p class="lead">{item.description}</p>
			<div class="meta-row">
				<span class="badge badge--accent">{item.viewMode}</span>
				<span class="badge">
					{item.entries.length} part{item.entries.length === 1 ? "" : "s"}
				</span>
				<span class="badge">{item.readingMinutes} min read</span>
			</div>
		</section>

		{item.overviewHtml && (
			<section class="panel hero-panel">
				<div class="prose" set:html={item.overviewHtml} />
			</section>
		)}

		{item.viewMode !== "merged" && (
			<section class="panel hero-panel">
				<div style="margin-bottom: 20px;">
					<span class="eyebrow">Series view</span>
					<h2 style="margin-top: 12px;">Read it chapter by chapter.</h2>
				</div>
				<EntryList item={item} />
			</section>
		)}

		{item.viewMode !== "series" && (
			<section class="panel hero-panel">
				<div style="margin-bottom: 20px;">
					<span class="eyebrow">Merged article</span>
					<h2 style="margin-top: 12px;">Read the whole item in one pass.</h2>
				</div>
				<div
					class="prose merged-stack"
					data-note-scope
					data-note-page={`${collection.route}/${item.slug}`}
					set:html={item.mergedHtml}
				/>
			</section>
		)}
	</div>

	<SectionNotes />
</Layout>
