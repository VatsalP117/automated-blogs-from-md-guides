---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import SectionNotes from "@/components/SectionNotes.astro";
import { loadSiteContent } from "@/lib/content/load-site";
import { withBase } from "@/lib/paths";
import Layout from "@/layouts/Layout.astro";
import type { ContentCollection, ContentEntry, ContentItem } from "@/lib/content/types";

export async function getStaticPaths() {
	const site = await loadSiteContent();

	return site.collections.flatMap((collection) =>
		collection.items
			.filter((item) => item.viewMode !== "merged")
			.flatMap((item) =>
				item.entries.map((entry) => ({
					params: {
						collection: collection.route,
						item: item.slug,
						entry: entry.slug,
					},
					props: {
						collection,
						item,
						entry,
					},
				})),
			),
	);
}

const { collection, item, entry } = Astro.props as {
	collection: ContentCollection;
	item: ContentItem;
	entry: ContentEntry;
};

const currentIndex = item.entries.findIndex((candidate) => candidate.slug === entry.slug);
const previousEntry = currentIndex > 0 ? item.entries[currentIndex - 1] : undefined;
const nextEntry = currentIndex < item.entries.length - 1 ? item.entries[currentIndex + 1] : undefined;
---

<Layout title={`${item.title}: ${entry.title}`} description={entry.description}>
	<Breadcrumbs
		items={[
			{ label: "Home", href: withBase() },
			{ label: collection.title, href: withBase(`${collection.route}/`) },
			{ label: item.title, href: withBase(`${collection.route}/${item.slug}/`) },
			{ label: entry.title },
		]}
	/>

	<div class="page-header">
		<h1>{entry.title}</h1>
		<div class="page-meta">
			<span>Part {entry.order} of {item.entries.length}</span>
			<span>{entry.readingMinutes} min read</span>
		</div>
	</div>

	<article>
		<div
			class="prose"
			data-note-scope
			data-note-page={`${collection.route}/${item.slug}/${entry.slug}`}
			set:html={entry.html}
		/>
	</article>

	<nav class="nav-links">
		{previousEntry ? (
			<a href={withBase(`${collection.route}/${item.slug}/${previousEntry.slug}/`)}>
				<span class="nav-label">← Previous</span>
				<strong>{previousEntry.title}</strong>
			</a>
		) : (
			<div class="nav-spacer" />
		)}
		{nextEntry ? (
			<a href={withBase(`${collection.route}/${item.slug}/${nextEntry.slug}/`)}>
				<span class="nav-label">Next →</span>
				<strong>{nextEntry.title}</strong>
			</a>
		) : (
			<div class="nav-spacer" />
		)}
	</nav>

	<SectionNotes />
</Layout>
