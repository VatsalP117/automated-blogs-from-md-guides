---
import CollectionCard from '@/components/CollectionCard.astro';
import { loadSiteContent } from '@/lib/content/load-site';
import { siteConfig } from '@/lib/config';
import { withBase } from '@/lib/paths';
import Layout from '@/layouts/Layout.astro';

const site = await loadSiteContent();
---

<Layout>
	<div class="page-header">
		<h1>{siteConfig.site.title}</h1>
		<p>{site.site.heroDescription}</p>
	</div>

	{site.collections.map((collection) => (
		<section style="margin-top: 40px;">
			<p class="section-label">{collection.title}</p>
			<div class="item-list">
				{collection.items.map((item) => (
					<CollectionCard
						href={withBase(`${collection.route}/${item.slug}/`)}
						title={item.title}
						description={item.description}
						badges={[
							`${item.entries.length} part${item.entries.length === 1 ? '' : 's'}`,
							`${item.readingMinutes} min read`,
						]}
					/>
				))}
			</div>
		</section>
	))}
</Layout>
