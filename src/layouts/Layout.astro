---
import { siteConfig } from '@/lib/config';
import { withBase } from '@/lib/paths';

interface Props {
	title?: string;
	description?: string;
}

const { title, description = siteConfig.site.description } = Astro.props;
const documentTitle = title ? `${title} | ${siteConfig.site.title}` : siteConfig.site.title;
const homeHref = withBase();
---

<!doctype html>
<html lang={siteConfig.site.language}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
		<link rel="icon" href={withBase('favicon.ico')} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{documentTitle}</title>
	</head>
	<body>
		<div class="site-shell">
			<header class="site-header">
				<a class="brand" href={homeHref}>
					<span class="brand-mark">///</span>
					<div>
						<p>{siteConfig.site.title}</p>
						<span>{siteConfig.site.tagline}</span>
					</div>
				</a>
				<nav class="site-nav">
					<a href={homeHref}>Home</a>
					{siteConfig.collections.map((collection) => (
						<a href={withBase(`${collection.route}/`)}>{collection.title}</a>
					))}
				</nav>
			</header>
			<main class="page-frame">
				<slot />
			</main>
		</div>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #0f1722;
		--surface: rgba(18, 29, 42, 0.72);
		--line: rgba(148, 163, 184, 0.18);
		--text: #f8fafc;
		--muted: #94a3b8;
		--accent: #f59e0b;
		--accent-soft: rgba(245, 158, 11, 0.16);
		--accent-strong: #fb923c;
		--max-width: 1180px;
		--serif: "Iowan Old Style", "Palatino Linotype", "URW Palladio L", Georgia, serif;
		--sans: "Avenir Next", "Segoe UI", sans-serif;
	}

	html {
		background:
			radial-gradient(circle at top left, rgba(245, 158, 11, 0.18), transparent 28%),
			radial-gradient(circle at 85% 10%, rgba(14, 165, 233, 0.16), transparent 22%),
			linear-gradient(180deg, #09111a 0%, #0f1722 100%);
		background-color: var(--bg);
		scroll-behavior: smooth;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		font-family: var(--sans);
		color: var(--text);
	}

	body {
		background-image:
			linear-gradient(rgba(148, 163, 184, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(148, 163, 184, 0.04) 1px, transparent 1px);
		background-size: 36px 36px;
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.site-shell {
		padding: 24px;
	}

	.site-header {
		width: min(100%, var(--max-width));
		margin: 0 auto 32px;
		display: flex;
		gap: 18px;
		align-items: center;
		justify-content: space-between;
		padding: 18px 22px;
		border: 1px solid var(--line);
		border-radius: 24px;
		background: rgba(9, 17, 26, 0.68);
		backdrop-filter: blur(14px);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 16px;
	}

	.brand-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 52px;
		height: 52px;
		border-radius: 16px;
		background: linear-gradient(135deg, rgba(245, 158, 11, 0.26), rgba(14, 165, 233, 0.22));
		font-family: var(--serif);
		font-size: 1.4rem;
		color: var(--accent);
	}

	.brand p,
	.brand span {
		margin: 0;
	}

	.brand p {
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.brand span {
		color: var(--muted);
		font-size: 0.92rem;
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		justify-content: flex-end;
	}

	.site-nav a {
		padding: 10px 14px;
		border-radius: 999px;
		color: var(--muted);
		transition: background-color 160ms ease, color 160ms ease;
	}

	.site-nav a:hover,
	.site-nav a:focus-visible {
		background: var(--accent-soft);
		color: var(--text);
		outline: none;
	}

	.page-frame {
		width: min(100%, var(--max-width));
		margin: 0 auto 48px;
	}

	.panel {
		border: 1px solid var(--line);
		border-radius: 28px;
		background: linear-gradient(180deg, rgba(18, 29, 42, 0.86), rgba(9, 17, 26, 0.9));
		box-shadow: 0 24px 64px rgba(0, 0, 0, 0.25);
	}

	.hero-panel {
		padding: clamp(28px, 4vw, 48px);
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.eyebrow::before {
		content: "";
		width: 28px;
		height: 1px;
		background: currentColor;
	}

	h1,
	h2,
	h3 {
		font-family: var(--serif);
		font-weight: 600;
		line-height: 1.05;
		letter-spacing: -0.03em;
		margin: 0;
	}

	h1 {
		font-size: clamp(2.6rem, 5vw, 4.9rem);
		max-width: 12ch;
		margin-top: 18px;
	}

	h2 {
		font-size: clamp(1.85rem, 3vw, 2.6rem);
	}

	p {
		color: var(--muted);
		line-height: 1.7;
	}

	.lead {
		max-width: 68ch;
		font-size: 1.06rem;
	}

	.meta-row,
	.badge-row {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 18px;
	}

	.badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 12px;
		border-radius: 999px;
		background: rgba(148, 163, 184, 0.08);
		color: var(--text);
		font-size: 0.9rem;
	}

	.badge--accent {
		background: var(--accent-soft);
		color: #ffd7a6;
	}

	.section-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 18px;
		margin-top: 28px;
	}

	.card {
		padding: 22px;
		border: 1px solid var(--line);
		border-radius: 22px;
		background: rgba(9, 17, 26, 0.52);
		transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease;
	}

	.card:hover,
	.card:focus-within {
		transform: translateY(-3px);
		border-color: rgba(245, 158, 11, 0.28);
		background: rgba(15, 23, 34, 0.82);
	}

	.card h3 {
		margin: 10px 0;
		font-size: 1.5rem;
	}

	.card p {
		margin: 0 0 18px;
	}

	.card-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-weight: 600;
		color: var(--accent-strong);
	}

	.stack {
		display: grid;
		gap: 18px;
	}

	.route-shell {
		display: grid;
		gap: 28px;
	}

	.breadcrumbs {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		align-items: center;
		color: var(--muted);
		font-size: 0.92rem;
	}

	.breadcrumbs span {
		color: rgba(148, 163, 184, 0.45);
	}

	.entry-list {
		display: grid;
		gap: 12px;
	}

	.entry-list a {
		display: grid;
		gap: 6px;
		padding: 16px 18px;
		border-radius: 18px;
		background: rgba(148, 163, 184, 0.06);
		border: 1px solid transparent;
	}

	.entry-list a:hover,
	.entry-list a:focus-visible {
		border-color: rgba(14, 165, 233, 0.24);
		background: rgba(14, 165, 233, 0.08);
		outline: none;
	}

	.entry-index {
		font-size: 0.8rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.prose {
		display: grid;
		gap: 1.25rem;
	}

	.prose :where(p, li, blockquote) {
		font-family: var(--serif);
		font-size: 1.08rem;
		line-height: 1.85;
		color: rgba(248, 250, 252, 0.94);
	}

	.prose :where(ul, ol) {
		margin: 0;
		padding-left: 1.4rem;
	}

	.prose :where(h2, h3, h4) {
		margin-top: 2.2rem;
	}

	.prose code {
		padding: 0.16rem 0.36rem;
		border-radius: 0.42rem;
		background: rgba(148, 163, 184, 0.12);
		font-family: "SFMono-Regular", "SF Mono", Menlo, Consolas, monospace;
		font-size: 0.9em;
	}

	.prose pre {
		overflow-x: auto;
		padding: 1rem 1.1rem;
		border-radius: 1rem;
		background: rgba(2, 6, 23, 0.88);
		border: 1px solid rgba(148, 163, 184, 0.12);
	}

	.prose pre code {
		padding: 0;
		background: transparent;
	}

	.prose blockquote {
		margin: 0;
		padding-left: 1rem;
		border-left: 3px solid rgba(245, 158, 11, 0.5);
		color: rgba(248, 250, 252, 0.76);
	}

	.merged-stack {
		display: grid;
		gap: 22px;
	}

	.merged-section {
		padding-top: 22px;
		border-top: 1px solid rgba(148, 163, 184, 0.14);
	}

	.kicker {
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--accent);
		margin-bottom: 8px;
	}

	.nav-links {
		display: flex;
		justify-content: space-between;
		gap: 16px;
	}

	.nav-links a,
	.nav-links div {
		flex: 1;
	}

	.nav-links a {
		padding: 18px;
		border-radius: 20px;
		border: 1px solid var(--line);
		background: rgba(9, 17, 26, 0.64);
	}

	.nav-links a:last-child {
		text-align: right;
	}

	.muted {
		color: var(--muted);
	}

	@media (max-width: 820px) {
		.site-shell {
			padding: 16px;
		}

		.site-header {
			flex-direction: column;
			align-items: flex-start;
		}

		.site-nav {
			justify-content: flex-start;
		}

		.nav-links {
			flex-direction: column;
		}
	}
</style>
