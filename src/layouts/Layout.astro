---
import { siteConfig } from '@/lib/config';
import { withBase } from '@/lib/paths';
import ThemeToggle from '@/components/ThemeToggle.astro';

interface Props {
	title?: string;
	description?: string;
}

const { title, description = siteConfig.site.description } = Astro.props;
const documentTitle = title ? `${title} — ${siteConfig.site.title}` : siteConfig.site.title;
const homeHref = withBase();
---

<!doctype html>
<html lang={siteConfig.site.language}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
		<link rel="icon" href={withBase('favicon.ico')} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{documentTitle}</title>
		<script is:inline>
			(function () {
				const saved = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const theme = saved || (prefersDark ? 'dark' : 'light');
				if (theme === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
			})();
		</script>
	</head>
	<body>
		<div class="site-shell">
			<header class="site-header">
				<a class="site-name" href={homeHref}>{siteConfig.site.title}</a>
				<div class="header-actions">
					<nav class="site-nav">
						{siteConfig.collections.map((collection) => (
							<a href={withBase(`${collection.route}/`)}>{collection.title}</a>
						))}
					</nav>
					<ThemeToggle />
				</div>
			</header>
			<main class="page-content">
				<slot />
			</main>
			<footer class="site-footer">
				<p>{siteConfig.site.title}</p>
			</footer>
		</div>
	</body>
</html>

<style is:global>
	/* ── Reset & Base ─────────────────────────────── */

	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
	}

	:root {
		--bg: #fafafa;
		--text: #111;
		--text-secondary: #555;
		--text-tertiary: #888;
		--border: #e0e0e0;
		--accent: #3d6b7e;
		--accent-hover: #2c5060;
		--code-bg: #f0f0f0;
		--code-border: #ddd;
		--pre-bg: #1e1e1e;
		--pre-border: #333;
		--pre-text: #d4d4d4;
		--reading-width: 680px;
		--page-width: 780px;
		--font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
			"Helvetica Neue", Arial, sans-serif;
		--font-mono: "SFMono-Regular", "SF Mono", Menlo, Consolas,
			"Liberation Mono", monospace;
	}

	[data-theme="dark"] {
		--bg: #0d0d0d;
		--text: #e8e8e8;
		--text-secondary: #a0a0a0;
		--text-tertiary: #707070;
		--border: #2a2a2a;
		--accent: #6b9eb3;
		--accent-hover: #8ab4c5;
		--code-bg: #1a1a1a;
		--code-border: #2a2a2a;
		--pre-bg: #1e1e1e;
		--pre-border: #333;
		--pre-text: #d4d4d4;
	}

	html {
		background: var(--bg);
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	body {
		font-family: var(--font-sans);
		font-size: 15px;
		line-height: 1.6;
		color: var(--text);
		min-height: 100vh;
	}

	a {
		color: var(--accent);
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	/* ── Shell ────────────────────────────────────── */

	.site-shell {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	/* ── Header ───────────────────────────────────── */

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--page-width);
		width: 100%;
		margin: 0 auto;
		padding: 28px 24px 24px;
	}

	.site-name {
		font-size: 15px;
		font-weight: 600;
		color: var(--text);
		text-decoration: none;
		letter-spacing: -0.01em;
	}

	.site-name:hover {
		text-decoration: none;
		color: var(--text-secondary);
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.site-nav {
		display: flex;
		gap: 20px;
	}

	.site-nav a {
		font-size: 14px;
		color: var(--text-secondary);
		text-decoration: none;
		transition: color 120ms ease;
	}

	.site-nav a:hover {
		color: var(--text);
		text-decoration: none;
	}

	/* ── Main Content ─────────────────────────────── */

	.page-content {
		flex: 1;
		width: 100%;
		max-width: var(--page-width);
		margin: 0 auto;
		padding: 0 24px 64px;
	}

	/* ── Footer ───────────────────────────────────── */

	.site-footer {
		max-width: var(--page-width);
		width: 100%;
		margin: 0 auto;
		padding: 24px 24px 32px;
		border-top: 1px solid var(--border);
	}

	.site-footer p {
		font-size: 13px;
		color: var(--text-tertiary);
	}

	/* ── Page Sections ────────────────────────────── */

	.page-header {
		margin-bottom: 40px;
	}

	.page-header h1 {
		font-size: 1.85rem;
		font-weight: 650;
		letter-spacing: -0.025em;
		line-height: 1.2;
		color: var(--text);
	}

	.page-header p {
		margin-top: 10px;
		font-size: 15px;
		line-height: 1.65;
		color: var(--text-secondary);
		max-width: 56ch;
	}

	.page-meta {
		margin-top: 12px;
		font-size: 13px;
		color: var(--text-tertiary);
	}

	.page-meta span + span::before {
		content: "·";
		margin: 0 8px;
		color: var(--border);
	}

	/* ── Breadcrumbs ──────────────────────────────── */

	.breadcrumbs {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		align-items: center;
		font-size: 13px;
		color: var(--text-tertiary);
		margin-bottom: 24px;
	}

	.breadcrumbs a {
		color: var(--text-tertiary);
		text-decoration: none;
	}

	.breadcrumbs a:hover {
		color: var(--text);
		text-decoration: underline;
	}

	.breadcrumbs .sep {
		color: var(--border);
		font-size: 11px;
	}

	/* ── Item List (replaces cards + grid) ─────────── */

	.item-list {
		display: grid;
		gap: 0;
	}

	.item-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 16px;
		padding: 14px 0;
		border-bottom: 1px solid var(--border);
		text-decoration: none;
		transition: background 100ms ease;
	}

	.item-row:first-child {
		border-top: 1px solid var(--border);
	}

	.item-row:hover {
		text-decoration: none;
		background: var(--code-bg);
	}

	.item-row-title {
		font-size: 15px;
		font-weight: 500;
		color: var(--text);
	}

	.item-row:hover .item-row-title {
		color: var(--accent);
	}

	.item-row-meta {
		font-size: 13px;
		color: var(--text-tertiary);
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* ── Chapter List ─────────────────────────────── */

	.chapter-list {
		display: grid;
		gap: 0;
	}

	.chapter-row {
		display: grid;
		grid-template-columns: 28px 1fr auto;
		align-items: baseline;
		gap: 12px;
		padding: 12px 0;
		border-bottom: 1px solid var(--border);
		text-decoration: none;
	}

	.chapter-row:first-child {
		border-top: 1px solid var(--border);
	}

	.chapter-row:hover {
		text-decoration: none;
		background: var(--code-bg);
	}

	.chapter-num {
		font-size: 13px;
		color: var(--text-tertiary);
		font-variant-numeric: tabular-nums;
		text-align: right;
	}

	.chapter-title {
		font-size: 15px;
		font-weight: 500;
		color: var(--text);
	}

	.chapter-row:hover .chapter-title {
		color: var(--accent);
	}

	.chapter-time {
		font-size: 13px;
		color: var(--text-tertiary);
		white-space: nowrap;
	}

	/* ── Section Label ────────────────────────────── */

	.section-label {
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-tertiary);
		margin-bottom: 12px;
	}

	/* ── Prose ─────────────────────────────────────── */

	.prose {
		max-width: var(--reading-width);
	}

	.prose :where(p, li, blockquote) {
		font-size: 16px;
		line-height: 1.8;
		color: var(--text);
	}

	.prose :where(p) {
		margin-top: 1.25em;
	}

	.prose :where(p):first-child {
		margin-top: 0;
	}

	.prose :where(ul, ol) {
		margin: 1em 0;
		padding-left: 1.5rem;
	}

	.prose :where(li) {
		margin-top: 0.35em;
	}

	.prose :where(h1) {
		font-size: 1.65rem;
		font-weight: 650;
		letter-spacing: -0.02em;
		line-height: 1.25;
		margin-top: 2.5rem;
	}

	.prose :where(h2) {
		font-size: 1.35rem;
		font-weight: 600;
		letter-spacing: -0.015em;
		line-height: 1.3;
		margin-top: 2.5rem;
		padding-bottom: 8px;
		border-bottom: 1px solid var(--border);
	}

	.prose :where(h3) {
		font-size: 1.1rem;
		font-weight: 600;
		line-height: 1.35;
		margin-top: 2rem;
	}

	.prose :where(h4) {
		font-size: 1rem;
		font-weight: 600;
		line-height: 1.4;
		margin-top: 1.5rem;
	}

	.prose code {
		padding: 0.15em 0.35em;
		border-radius: 4px;
		background: var(--code-bg);
		font-family: var(--font-mono);
		font-size: 0.85em;
	}

	.prose pre {
		overflow-x: auto;
		padding: 16px 20px;
		border-radius: 6px;
		background: var(--pre-bg);
		border: 1px solid var(--pre-border);
		margin-top: 1.25em;
	}

	.prose pre code {
		padding: 0;
		background: transparent;
		color: var(--pre-text);
		font-size: 13px;
		line-height: 1.6;
	}

	.prose blockquote {
		margin: 1.25em 0;
		padding: 0 0 0 16px;
		border-left: 3px solid var(--border);
		color: var(--text-secondary);
	}

	.prose :where(strong) {
		font-weight: 600;
	}

	.prose :where(a) {
		color: var(--accent);
		text-decoration: underline;
		text-decoration-color: rgba(61, 107, 126, 0.3);
		text-underline-offset: 2px;
	}

	.prose :where(a):hover {
		text-decoration-color: var(--accent);
	}

	.prose :where(table) {
		width: 100%;
		border-collapse: collapse;
		margin-top: 1.25em;
		font-size: 14px;
	}

	.prose :where(th, td) {
		padding: 8px 12px;
		border: 1px solid var(--border);
		text-align: left;
	}

	.prose :where(th) {
		background: var(--code-bg);
		font-weight: 600;
	}

	.prose :where(img) {
		max-width: 100%;
		height: auto;
		border-radius: 6px;
		margin: 1.25em 0;
	}

	.prose :where(hr) {
		border: none;
		border-top: 1px solid var(--border);
		margin: 2.5rem 0;
	}

	/* ── Merged Stack ─────────────────────────────── */

	.merged-stack {
		display: grid;
		gap: 0;
	}

	.merged-section {
		padding-top: 2rem;
		margin-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.merged-section:first-child {
		padding-top: 0;
		margin-top: 0;
		border-top: none;
	}

	.kicker {
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-tertiary);
		margin-bottom: 12px;
	}

	/* ── Nav Links (Prev/Next) ────────────────────── */

	.nav-links {
		display: flex;
		justify-content: space-between;
		gap: 24px;
		margin-top: 48px;
		padding-top: 24px;
		border-top: 1px solid var(--border);
	}

	.nav-links a {
		display: block;
		flex: 1;
		text-decoration: none;
	}

	.nav-links a:hover {
		text-decoration: none;
	}

	.nav-links a:hover strong {
		color: var(--accent);
	}

	.nav-links a:last-child {
		text-align: right;
	}

	.nav-links .nav-label {
		display: block;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--text-tertiary);
		margin-bottom: 4px;
	}

	.nav-links strong {
		font-size: 15px;
		font-weight: 500;
		color: var(--text);
		transition: color 120ms ease;
	}

	.nav-links div.nav-spacer {
		flex: 1;
	}

	/* ── Responsive ───────────────────────────────── */

	@media (max-width: 640px) {
		.site-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 12px;
			padding: 20px 16px 16px;
		}

		.page-content {
			padding: 0 16px 48px;
		}

		.site-footer {
			padding: 20px 16px 24px;
		}

		.item-row {
			flex-direction: column;
			gap: 2px;
		}

		.chapter-row {
			grid-template-columns: 24px 1fr;
		}

		.chapter-time {
			display: none;
		}

		.nav-links {
			flex-direction: column;
			gap: 12px;
		}

		.nav-links a:last-child {
			text-align: left;
		}
	}
</style>
