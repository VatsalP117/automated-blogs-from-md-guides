---
import type { ContentItem } from "@/lib/content/types";
import { withBase } from "@/lib/paths";

interface Props {
	item: ContentItem;
}

const { item } = Astro.props;
---

<div class="chapter-list">
	{item.entries.map((entry) => (
		<a
			class="chapter-row"
			href={withBase(`${item.collectionRoute}/${item.slug}/${entry.slug}/`)}
		>
			<span class="chapter-num">{entry.order}</span>
			<span class="chapter-title">{entry.title}</span>
			<span class="chapter-time">{entry.readingMinutes} min</span>
		</a>
	))}
</div>
