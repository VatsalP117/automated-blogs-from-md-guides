---
interface Props {
	href: string;
	title: string;
	description: string;
	badges: string[];
	linkLabel?: string;
}

const { href, title, badges } = Astro.props;
const metaText = badges.filter(Boolean).join(" · ");
---

<a class="item-row" href={href}>
	<span class="item-row-title">{title}</span>
	<span class="item-row-meta">{metaText}</span>
</a>
